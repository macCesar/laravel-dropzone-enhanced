{
  "name": "maccesar/laravel-dropzone-enhanced",
  "description": "Enhanced Dropzone.js component for Laravel with file upload, thumbnails, and photo management",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Mac Cesar",
      "email": "contact@maccesar.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0|^13.0",
    "ext-exif": "*",
    "ext-gd": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5.50|^12.5.8",
    "orchestra/testbench": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "MacCesar\\LaravelDropzoneEnhanced\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MacCesar\\LaravelDropzoneEnhanced\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "MacCesar\\LaravelDropzoneEnhanced\\DropzoneServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
